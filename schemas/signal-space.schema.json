{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-space.github.io/signal-space-spec/schemas/signal-space.schema.json",
  "title": "Signal Space",
  "description": "Shared graph, timeline, inspector, decision, and intent surface for live signal systems.",
  "type": "object",
  "required": ["schema_version", "graph"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "graph": {
      "$ref": "#/$defs/SignalGraph"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "JsonObject": {
      "type": "object",
      "additionalProperties": true
    },
    "AuthorityLevel": {
      "type": "string",
      "enum": ["local", "advisory", "gated", "direct"]
    },
    "Authority": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": {
          "$ref": "#/$defs/AuthorityLevel"
        },
        "by_intent": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/AuthorityLevel"
          }
        },
        "owner": {
          "type": "string"
        },
        "boundary": {
          "type": "string",
          "enum": ["view", "adapter", "runtime", "product", "external"]
        },
        "requires_approval": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "StateClass": {
      "type": "string",
      "enum": ["observation", "recommendation", "action"]
    },
    "StateField": {
      "type": "object",
      "required": ["id", "state_class", "writable"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "state_class": {
          "$ref": "#/$defs/StateClass"
        },
        "writable": {
          "type": "boolean"
        },
        "derived": {
          "type": "boolean",
          "default": false
        },
        "schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "value": true
      },
      "additionalProperties": false
    },
    "SignalGraph": {
      "type": "object",
      "required": ["id", "nodes", "edges", "timeline", "intent_modules", "authority"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SignalNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SignalEdge"
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TimelineEvent"
          }
        },
        "inspectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InspectorPanel"
          },
          "default": []
        },
        "intent_modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntentModule"
          }
        },
        "allowed_intents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "authority": {
          "$ref": "#/$defs/Authority"
        },
        "snapshot": {
          "$ref": "#/$defs/Snapshot"
        }
      },
      "additionalProperties": false
    },
    "SignalNode": {
      "type": "object",
      "required": ["id", "family", "state", "authority", "allowed_intents"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "family": {
          "type": "string",
          "enum": ["source", "transform", "memory", "decision", "gate", "output"]
        },
        "mode": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "input_schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "output_schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "authority": {
          "$ref": "#/$defs/Authority"
        },
        "state": {
          "type": "object",
          "required": ["summary", "fields"],
          "properties": {
            "summary": {
              "type": "string"
            },
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/StateField"
              }
            }
          },
          "additionalProperties": false
        },
        "recent_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SignalEvent"
          },
          "default": []
        },
        "explanation": {
          "$ref": "#/$defs/JsonObject"
        },
        "decision": {
          "$ref": "#/$defs/DecisionEnvelope"
        },
        "allowed_modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "allowed_intents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "state_chart": {
          "$ref": "#/$defs/StateChart"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PortSpec"
          },
          "default": []
        },
        "io_binding": {
          "$ref": "#/$defs/IoBinding"
        },
        "provenance": {
          "$ref": "#/$defs/JsonObject"
        }
      },
      "additionalProperties": false
    },
    "SignalEdge": {
      "type": "object",
      "required": ["id", "from", "to"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "from": {
          "$ref": "#/$defs/Id"
        },
        "to": {
          "$ref": "#/$defs/Id"
        },
        "label": {
          "type": "string"
        },
        "schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "authority": {
          "$ref": "#/$defs/Authority"
        },
        "state_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StateField"
          },
          "default": []
        },
        "from_port": {
          "$ref": "#/$defs/Id",
          "description": "Output jack on the `from` node this cable is plugged into. Optional; when absent the edge is an untyped connection (0.2.0 behavior)."
        },
        "to_port": {
          "$ref": "#/$defs/Id",
          "description": "Input jack on the `to` node this cable is plugged into."
        },
        "stream_telemetry": {
          "$ref": "#/$defs/StreamTelemetry",
          "description": "Live-cable readout (rate, latency, freshness, preview). Declared as deterministic derived state; hosts MUST NOT treat these as writable cells."
        }
      },
      "additionalProperties": false
    },
    "SignalEvent": {
      "type": "object",
      "required": ["id", "kind", "state_class", "created_at"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "kind": {
          "type": "string"
        },
        "state_class": {
          "$ref": "#/$defs/StateClass"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "payload": {
          "$ref": "#/$defs/JsonObject"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "TimelineEvent": {
      "type": "object",
      "required": ["id", "kind", "state_class", "created_at", "node_id"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "kind": {
          "type": "string"
        },
        "state_class": {
          "$ref": "#/$defs/StateClass"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "payload": {
          "$ref": "#/$defs/JsonObject"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "default": []
        },
        "node_id": {
          "$ref": "#/$defs/Id"
        },
        "edge_id": {
          "$ref": "#/$defs/Id"
        },
        "run_id": {
          "$ref": "#/$defs/Id"
        },
        "decision_id": {
          "$ref": "#/$defs/Id"
        }
      },
      "additionalProperties": false
    },
    "InspectorPanel": {
      "type": "object",
      "required": ["id", "target", "sections"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "target": {
          "$ref": "#/$defs/Target"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "fields"],
            "properties": {
              "id": {
                "$ref": "#/$defs/Id"
              },
              "title": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/StateField"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "DecisionEnvelope": {
      "type": "object",
      "required": ["id", "mode", "capabilities", "inputs", "output_schema", "authority"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "mode": {
          "type": "string",
          "enum": ["deterministic", "model", "small_agent", "large_agent"]
        },
        "artifact": {
          "type": "string"
        },
        "feature_schema": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Id"
          }
        },
        "output_schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "explanation": {
          "$ref": "#/$defs/JsonObject"
        },
        "proposed_intents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SurfaceIntent"
          },
          "default": []
        },
        "authority": {
          "$ref": "#/$defs/AuthorityLevel"
        }
      },
      "additionalProperties": false
    },
    "IntentSchema": {
      "type": "object",
      "required": ["type", "authority", "payload_schema"],
      "properties": {
        "type": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/AuthorityLevel"
        },
        "target_families": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "payload_schema": {
          "$ref": "#/$defs/JsonObject"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "IntentModule": {
      "type": "object",
      "required": ["id", "version", "intents"],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "capability": {
          "type": "string",
          "enum": [
            "navigation",
            "layout",
            "graph_editing",
            "runtime",
            "labeling",
            "decision_inspection",
            "trainable_model",
            "inference_model",
            "agent_lifecycle",
            "approval",
            "audit",
            "product_adapter"
          ]
        },
        "intents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IntentSchema"
          }
        }
      },
      "additionalProperties": false
    },
    "SurfaceIntent": {
      "type": "object",
      "required": ["id", "type", "target", "payload", "actor", "authority", "created_at"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "type": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/Target"
        },
        "payload": {
          "$ref": "#/$defs/JsonObject"
        },
        "actor": {
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/AuthorityLevel"
        },
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Evidence"
          },
          "default": []
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "idempotency_key": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Target": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["graph", "node", "edge", "event", "timeline", "run", "decision", "inspector"]
        },
        "id": {
          "$ref": "#/$defs/Id"
        }
      },
      "additionalProperties": false
    },
    "Evidence": {
      "type": "object",
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Snapshot": {
      "type": "object",
      "required": ["id", "created_at", "read_only"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "delta_cursor": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StateChart": {
      "type": "object",
      "description": "Declarative finite state machine mirroring lazily's StateMachine<S, E>. Declares possible states and event-driven transitions; the owning adapter remains responsible for applying or rejecting any transition at its authority boundary.",
      "required": ["states", "initial", "transitions"],
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "initial": {
          "type": "string"
        },
        "current": {
          "type": "string",
          "description": "Live state of the machine, mirroring lazily's state() getter. Optional; when absent the live state lives in state.fields as before."
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "event", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "event": {
                "type": "string",
                "description": "Event that triggers the transition. Conventionally matches an intent type advertised by the graph or the node's allowed_intents so a SurfaceIntent doubles as a state-machine event."
              },
              "to": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "PortDirection": {
      "type": "string",
      "enum": ["in", "out"]
    },
    "PortDtype": {
      "type": "string",
      "enum": ["scalar", "vector", "event", "window", "decision", "label"],
      "description": "Jack type. Cables must connect compatible dtypes; a host SHOULD reject mismatched patches visibly."
    },
    "PortSpec": {
      "type": "object",
      "description": "A typed jack on a module. Added in 0.3.0. Edges may reference ports via from_port/to_port so the patchboard can dtype-check cables and render live telemetry per jack.",
      "required": ["id", "direction", "dtype"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Id"
        },
        "name": {
          "type": "string"
        },
        "direction": {
          "$ref": "#/$defs/PortDirection"
        },
        "dtype": {
          "$ref": "#/$defs/PortDtype"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether an in-port must be connected for the node to be considered valid/wired."
        }
      },
      "additionalProperties": false
    },
    "StreamTelemetry": {
      "type": "object",
      "description": "Live-cable readout for an edge. Added in 0.3.0. Always derived/observed state, never writable; connector failures surface here as missing_data / stale freshness.",
      "properties": {
        "rate_hz": {
          "type": "number",
          "minimum": 0
        },
        "latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "freshness_ms": {
          "type": "number",
          "minimum": 0
        },
        "last_value_preview": true,
        "distribution_hint": true,
        "missing_data": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "IoDirection": {
      "type": "string",
      "enum": ["ingress", "egress"]
    },
    "IoTransport": {
      "type": "string",
      "enum": ["webhook", "websocket", "file_tail", "timer", "stdin_jsonl", "exec", "notify", "mcp"],
      "description": "How a source/output node binds to the outside world. Secrets are never inlined; auth_ref names a host-resolved credential."
    },
    "IoBinding": {
      "type": "object",
      "description": "Declares how a node binds to an external transport. Added in 0.3.0. ingress bindings are restricted to source nodes; egress bindings to gate/output nodes; egress must never carry direct authority.",
      "required": ["direction", "transport"],
      "properties": {
        "direction": {
          "$ref": "#/$defs/IoDirection"
        },
        "transport": {
          "$ref": "#/$defs/IoTransport"
        },
        "endpoint": {
          "type": "string",
          "description": "Transport address (URL, path, topic). Non-secret."
        },
        "format": {
          "type": "string",
          "description": "Wire format hint, e.g. json, jsonl, ndjson."
        },
        "schema_ref": {
          "type": "string",
          "description": "Optional reference to the payload schema."
        },
        "auth_ref": {
          "type": "string",
          "description": "Name of a host-resolved credential. The document never carries the secret itself."
        }
      },
      "additionalProperties": false
    }
  }
}
